# ============================================================
# Real-Time Biscuit Quality Inspection System — Environment
# ============================================================

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=biscuit_inspection
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# --- JWT Auth ---
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# --- SendGrid OTP ---
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_SENDER_EMAIL=noreply@biscuitai.com
SENDGRID_SENDER_NAME=BiscuitAI System

# --- Backend Server ---
BACKEND_PORT=5000
FRONTEND_PORT=3000
NODE_ENV=development

# --- Model Paths (relative to project root) ---
MONACO_MODEL_PATH=models/monaco_best.pt
PARLE_MODEL_PATH=models/parle_best.pt
MARIE_MODEL_PATH=models/marie_best.pt

# --- Per-model confidence thresholds ---
# Monaco needs lower threshold (fewer training images = lower raw confidence)
# DO NOT raise above 0.45 — Monaco and Marie Broken will disappear
MONACO_CONF=0.25
PARLE_CONF=0.38
MARIE_CONF=0.30
CONFIDENCE_THRESHOLD=0.50

# --- Detection Settings ---
IOU_THRESHOLD=0.45
CAMERA_INDEX=0

# FRAME_SKIP=2 means inference every 2nd frame
# Camera display still runs at full 30fps (separate thread)
# Set to 1 if you have a fast GPU (RTX 3060+)
# Set to 3 if CPU-only and getting lag
FRAME_SKIP=1

# JPEG quality for SocketIO stream (lower = faster, less bandwidth)
JPEG_QUALITY=75

# --- Export ---
EXPORT_DIR=exports/
